---
import Layout from "../layouts/Layout.astro";
import CounterTile from "../components/counter_tile";
import Map from "../components/map";
import { DuckDBInstance, DuckDBListValue } from "@duckdb/node-api";
import { DateTime } from "luxon";
import type { CounterStat } from "../lib/types";
import _ from "lodash";
import { Image } from "astro:assets";

// Build-time data loading - replaces getStaticProps
const instance = await DuckDBInstance.create("compteurs.duckdb", {
	access_mode: "READ_ONLY",
});
const connection = await instance.connect();

const metadata = await connection.run(
	"SELECT name, slug, longitude, latitude, yesterday, week, month, year, total, days, days_this_year, single_counters FROM counter_group ORDER BY yesterday DESC",
);
const rows = await metadata.getRows();
const counts: CounterStat[] = rows.map((row) => {
	return {
		id: row[0].toString(),
		slug: row[1].toString(),
		day: (row[4] as number) || 0,
		week: (row[5] as number) || 0,
		month: (row[6] as number) || 0,
		year: (row[7] as number) || 0,
		total: (row[8] as number) || 0,
		days: (row[9] as number) || 0,
		daysThisYear: (row[10] as number) || 0,
		included: (row[11] as DuckDBListValue).items as string[],
		coordinates: [(row[2] as number) || 0, (row[3] as number) || 0] as [
			number,
			number,
		],
	};
});

const buildTime = DateTime.local().toFormat("dd/LL/yyyy à HH:mm");
---

<Layout title="Compteurs vélo à Paris">
  <div class="page-container">
    <a href="https://parisenselle.fr">
      <Image
        priority
        class="logo-link"
        src="/logo.png"
        alt="Logo Paris en Selle"
        width="80"
        height="80"
      />
    </a>
    <h1>Compteurs vélo à Paris</h1>
    <p class="build-info">Page générée le {buildTime}</p>
  </div>

  <div class="sort-controls">
    <div>
      <div>
        <input
          type="radio"
          id="avg"
          name="average"
          checked
          class="sort-trigger"
          data-avg="true"
        />
        <label for="avg">moyenne journalière</label>
      </div>
      <div>
        <input
          type="radio"
          id="total"
          name="average"
          class="sort-trigger"
          data-avg="false"
        />
        <label for="total">nombre total de passages</label>
      </div>
    </div>
    <div>
      Trier par activité décroissante sur :
      <div class="sort-select-container">
        <select
          class="sort-select"
          name="order"
          id="order"
        >
          <option value="day">la journée de hier</option>
          <option value="week">les 7 derniers jours</option>
          <option value="month">les 30 derniers jours</option>
          <option value="year">l'année en cours</option>
          <option value="days">l'ancienneté</option>
        </select>
        <div class="sort-select-arrow">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
          >
            <path
              d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"
            ></path>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div class="counters-grid">
    <div class="map-container">
      <Map client:load counters={counts} />
    </div>
    {
      counts.map((stat, index) => (
        <div
          class="counter-card"
          data-stat={JSON.stringify(stat)}
          data-rank={index + 1}
        >
          <CounterTile
            client:visible
            stat={stat}
            avg={true}
            rank={index + 1}
            counterCount={counts.length}
          />
        </div>
      ))
    }
  </div>

  <div class="footer-info">
    <p>
      Source :{' '}
      <a
        href="https://parisdata.opendatasoft.com/explore/dataset/comptage-velo-donnees-compteurs/information/"
      >
        données ouvertes de la ville de Paris
      </a>
    </p>
    <p>
      Données sous licence{' '}
      <a href="https://opendatacommons.org/licenses/odbl/">ODbL</a>
    </p>
    <p>
      <a href="https://github.com/Tristramg/velos-paris">
        Code source de la page
      </a>{' '}
      sous licence MIT
    </p>
  </div>
</Layout>

<script>
  // Client-side interactivity
  import _ from 'lodash';

  let currentSort = 'day';
  let isAvg = true;

  function updateVisibility() {
    const tiles = document.querySelectorAll('[data-stat]');
    const sortedStats = _.sortBy(
      Array.from(tiles).map((tile) => {
        const stat = JSON.parse(tile.getAttribute('data-stat') || '{}');
        return { element: tile, stat };
      }),
      (item: any) => item.stat[currentSort]
    ).reverse();

    sortedStats.forEach((item: any, index: number) => {
      item.element.style.order = index;
      // Update rank display if needed
    });
  }

  document.getElementById('order')?.addEventListener('change', (e) => {
    currentSort = (e.target as HTMLSelectElement).value;
    updateVisibility();
  });

  document.querySelectorAll('.sort-trigger').forEach((trigger) => {
    trigger.addEventListener('change', (e) => {
      isAvg =
        (e.target as HTMLInputElement).getAttribute('data-avg') === 'true';
      // Update avg state in components
    });
  });
</script>
